{
  "expo": {
    "name": "Schedulite",
    "slug": "schedulite-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "schedulite",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0f0f12"
    },
    "plugins": [
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.YOUR_IOS_CLIENT_ID"
        }
      ]
    ],
    "extra": {
      "googleWebClientId": ""
    }
  }
}
